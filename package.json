{
  "name": "pi-work-guard",
  "version": "0.2.0",
  "description": "Memory-safe workflow guard for Pi: phase budgets, checkpoints, command risk warnings, and file-size checks.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "workflow-guard",
    "memory-safety"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check:file-size": "node scripts/check-file-size.mjs",
    "test:unit": "node --test tests/*.test.mjs",
    "test": "npm run typecheck && npm run test:unit && npm run check:file-size"
  },
  "files": [
    "extensions",
    "scripts",
    "src",
    "tests",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
